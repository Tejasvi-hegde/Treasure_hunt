# ── Treasure Hunt Backend — Environment Variables ────────────
# Copy this file to .env and fill in the values.
# NEVER commit your actual .env file to git.

# Server port (Render/Railway sets this automatically)
PORT=3003

# A long random string — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=7766f94e109aecdaf3ec8cad95f4c91c5655d4f5f01e1d9a6669d207e06b9843b91eae56f01100410ca346000a943f8e

# Admin dashboard password
ADMIN_KEY=treasurehunt

# Your deployed frontend URL (comma-separated for multiple)
# Example: https://treasure-hunt.vercel.app
FRONTEND_URL=http://localhost:5500

# Set to "false" to close registration after all teams have signed up
REGISTRATION_OPEN=true

# SQLite database path (default: ./treasure_hunt.db)
# DB_PATH=./treasure_hunt.db
